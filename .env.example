# Copia este archivo a .env y ajusta los valores reales.
#   cp .env.example .env

# URL base del backend NestJS (incluye el prefijo /api)
VITE_API_URL=http://localhost:3000/api

# Pusher Channels (tiempo real). Deben coincidir con el backend-laravel:
#   VITE_PUSHER_APP_KEY     = PUSHER_APP_KEY
#   VITE_PUSHER_APP_CLUSTER = PUSHER_APP_CLUSTER
VITE_PUSHER_APP_KEY=
VITE_PUSHER_APP_CLUSTER=sa1
